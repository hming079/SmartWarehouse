# ==========================================================
# SmartWarehouse backend database config
# Switch between docker and local by changing DB_MODE only.
# ==========================================================

# Choose one: docker | local
DB_MODE=docker

# Shared
DB_NAME=SmartWarehouse
DB_PORT=1433

# ---------------- Docker SQL Server ----------------
# Use these when DB_MODE=docker
# If backend runs on host machine: 127.0.0.1 (port mapped from container)
# If backend runs inside another container in same compose network: mssql
# DB_HOST=127.0.0.1
# DB_USER=sa
# DB_PASSWORD=YourStrong!Passw0rd

# ---------------- Local SQL Server -----------------
# Use these when DB_MODE=local
# DB_HOST=127.0.0.1
# DB_USER=sa
# DB_PASSWORD=YourLocalSqlPassword
